        {"id": "superproject-bringup-observation", "actor_role": "superproject-bringup-observer", "verifier_roles": ["cross-stack-verification-engineer"], "required_capabilities": ["bringup.observe"], "gate": "software-bringup", "artifacts": ["first_red_report", "sha_manifest", "owner_handoff"]}
      ]
    },
    {
      "id": "architecture",
      "purpose": "Frozen ISA through functional oracle, cycle-accurate model, and cross-model compatibility.",
      "inputs": ["frozen_isa", "functional_oracle"],
      "outputs": ["correlation_evidence", "model_compatibility_report", "architecture_release_record"],
      "stop_policy": "first_red_hard_break",
      "stages": [
        {"id": "architecture-contract", "actor_role": "steward", "verifier_roles": ["isa-architect", "harness-auditor"], "required_capabilities": ["assignment.issue"], "gate": "contract-integrity", "artifacts": ["hypothesis", "baseline", "sensitivity_plan"]},
        {"id": "architecture-model", "actor_role": "senior-coder", "verifier_roles": ["cross-stack-verification-engineer"], "required_capabilities": ["code.modify"], "gate": "architecture-correlation", "artifacts": ["model_patch", "differential", "counter_report"]},
        {"id": "architecture-model-compatibility", "actor_role": "isa-verification-engineer", "verifier_roles": ["cross-stack-verification-engineer"], "required_capabilities": ["isa.compatibility.audit"], "gate": "architecture-compatibility", "artifacts": ["model_compatibility_matrix", "first_mismatch_report", "ownership_route"]},
