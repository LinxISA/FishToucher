      "stages": [
        {"id": "software-contract", "actor_role": "steward", "verifier_roles": ["isa-architect", "harness-auditor"], "required_capabilities": ["assignment.issue"], "gate": "contract-integrity", "artifacts": ["task_graph", "impact_matrix", "proof_plan"]},
        {"id": "isa-golden-review", "actor_role": "isa-architect", "verifier_roles": ["isa-verification-engineer"], "required_capabilities": ["isa.golden.review"], "gate": "isa-golden-quality", "artifacts": ["golden_consistency_report", "encoding_conflict_report", "normative_issue_list"]},
        {"id": "llvm-design", "actor_role": "llvm-designer", "verifier_roles": ["llvm-verification-engineer"], "required_capabilities": ["llvm.design"], "gate": "llvm-contract", "artifacts": ["llvm_patch", "lit_regression", "dual_width_compile_evidence"]},
