{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://linx-isa.github.io/FishToucher/schemas/evidence.schema.json",
  "title": "FishToucher Prototype Evidence",
  "type": "object",
  "required": ["contract", "kind", "run_id", "profile", "lane", "gate_id", "command", "cwd", "started_at", "finished_at", "status", "return_code", "artifacts", "sha_manifest", "dirty_tree", "actor"],
  "properties": {
    "contract": {"const": "fishtoucher.prototype"}, "kind": {"const": "evidence"},
    "status": {"enum": ["pass", "fail", "timeout", "crash", "skipped", "waived"]},
    "return_code": {"type": "integer"}, "artifacts": {"type": "array", "minItems": 1},
    "actor": {"type": "object", "required": ["name", "role_id", "driver_id", "model"]}
  },
  "additionalProperties": true
}
