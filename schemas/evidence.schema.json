{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://linx-isa.github.io/FishToucher/schemas/evidence.schema.json",
  "title": "FishToucher Gate Evidence",
  "type": "object",
  "required": [
    "run_id",
    "profile",
    "lane",
    "gate_id",
    "command",
    "cwd",
    "started_at",
    "finished_at",
    "status",
    "return_code",
    "artifacts",
    "sha_manifest",
    "dirty_tree",
    "agent"
  ],
  "properties": {
    "status": {
      "enum": ["pass", "fail", "timeout", "crash", "skipped", "waived"]
    },
    "artifacts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["path", "sha256"]
      }
    },
    "dirty_tree": {"type": "boolean"}
  },
  "additionalProperties": true
}
