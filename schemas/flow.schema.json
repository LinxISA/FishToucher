{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://linx-isa.github.io/FishToucher/schemas/flow.schema.json",
  "title": "FishToucher Prototype Flow",
  "type": "object",
  "required": ["contract", "project", "human_authority", "drivers", "roles", "gates", "loops", "budgets", "anti_cheat"],
  "properties": {
    "contract": {"const": "fishtoucher.prototype"},
    "project": {"type": "object"},
    "human_authority": {"type": "object"},
    "drivers": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/driver"}},
    "roles": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/role"}},
    "gates": {"type": "array", "minItems": 1},
    "loops": {"type": "array", "minItems": 3, "maxItems": 3},
    "budgets": {
      "type": "object",
      "required": ["max_context_sections", "max_context_bytes", "max_delegated_calls", "max_parallel_agents", "max_depth"],
      "properties": {
        "max_context_sections": {"type": "integer", "minimum": 1, "maximum": 8},
        "max_context_bytes": {"type": "integer", "minimum": 1, "maximum": 32768},
        "max_delegated_calls": {"type": "integer", "minimum": 0, "maximum": 4},
        "max_parallel_agents": {"type": "integer", "minimum": 1, "maximum": 6},
        "max_depth": {"type": "integer", "minimum": 1, "maximum": 2}
      },
      "additionalProperties": false
    },
    "anti_cheat": {"type": "object"}
  },
  "$defs": {
    "stringList": {"type": "array", "items": {"type": "string", "minLength": 1}, "uniqueItems": true},
    "driver": {
      "type": "object",
      "required": ["id", "kind", "provider", "model", "enabled", "capabilities", "credential_env"],
      "properties": {
        "id": {"type": "string"}, "kind": {"type": "string"}, "provider": {"type": "string"},
        "model": {"type": "string"}, "enabled": {"type": "boolean"},
        "capabilities": {"$ref": "#/$defs/stringList"}, "credential_env": {"type": ["string", "null"]}
      },
      "additionalProperties": false
    },
    "role": {
      "type": "object",
      "required": ["id", "title", "job_family", "objective", "capabilities", "permissions", "provider_policy", "inputs", "outputs", "definition_of_done", "escalate_when"],
      "properties": {
        "id": {"type": "string"}, "title": {"type": "string"}, "job_family": {"type": "string"},
        "objective": {"type": "string"}, "capabilities": {"$ref": "#/$defs/stringList"},
        "permissions": {"type": "object"}, "provider_policy": {"type": "object"},
        "inputs": {"$ref": "#/$defs/stringList"}, "outputs": {"$ref": "#/$defs/stringList"},
        "definition_of_done": {"$ref": "#/$defs/stringList"}, "escalate_when": {"$ref": "#/$defs/stringList"}
      },
      "additionalProperties": false
    }
  }
}
