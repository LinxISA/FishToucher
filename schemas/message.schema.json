{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://linx-isa.github.io/FishToucher/schemas/message.schema.json",
  "title": "FishToucher Prototype Message",
  "type": "object",
  "required": ["contract", "message_id", "run_id", "sequence", "kind", "sender", "recipients", "in_reply_to", "created_at", "payload"],
  "properties": {
    "contract": {"const": "fishtoucher.prototype"},
    "message_id": {"type": "string", "minLength": 1}, "run_id": {"type": "string", "minLength": 1},
    "sequence": {"type": "integer", "minimum": 1}, "kind": {"enum": ["assignment", "result", "verdict", "escalation"]},
    "sender": {
      "type": "object", "required": ["name", "role_id", "driver_id", "model"],
      "properties": {"name": {"type": "string"}, "role_id": {"type": "string"}, "driver_id": {"type": "string"}, "model": {"type": "string"}},
      "additionalProperties": false
    },
    "recipients": {"type": "array", "minItems": 1, "uniqueItems": true},
    "in_reply_to": {"type": ["string", "null"]}, "created_at": {"type": "string", "format": "date-time"},
    "payload": {"type": "object"}
  },
  "additionalProperties": false
}
