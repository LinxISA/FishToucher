{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://linxisa.github.io/FishToucher/schemas/message.schema.json",
  "title": "FishToucher Agent Message",
  "type": "object",
  "required": [
    "protocol",
    "message_id",
    "run_id",
    "sequence",
    "kind",
    "sender",
    "recipients",
    "in_reply_to",
    "created_at",
    "payload"
  ],
  "properties": {
    "protocol": {"const": "fishtoucher.message/v1"},
    "message_id": {"type": "string", "minLength": 1},
    "run_id": {"type": "string", "minLength": 1},
    "sequence": {"type": "integer", "minimum": 1},
    "kind": {
      "enum": [
        "observation",
        "work_packet",
        "ack",
        "question",
        "answer",
        "result",
        "verdict",
        "feedback",
        "escalation"
      ]
    },
    "sender": {
      "type": "object",
      "required": ["role", "provider", "model"],
      "properties": {
        "role": {"type": "string", "minLength": 1},
        "provider": {"type": "string", "minLength": 1},
        "model": {"type": "string", "minLength": 1}
      },
      "additionalProperties": false
    },
    "recipients": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {"type": "string", "minLength": 1}
    },
    "in_reply_to": {
      "type": ["string", "null"],
      "minLength": 1
    },
    "created_at": {
      "type": "string",
      "format": "date-time",
      "pattern": "Z$"
    },
    "payload": {
      "type": "object",
      "required": ["summary"],
      "properties": {
        "summary": {"type": "string", "minLength": 1},
        "artifacts": {"type": "array"},
        "claims": {"type": "array"},
        "requests": {"type": "array"}
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": false,
  "allOf": [
    {
      "if": {
        "properties": {
          "kind": {
            "enum": [
              "work_packet",
              "ack",
              "question",
              "answer",
              "result",
              "verdict",
              "feedback"
            ]
          }
        }
      },
      "then": {
        "properties": {
          "in_reply_to": {"type": "string", "minLength": 1}
        }
      }
    },
    {
      "if": {"properties": {"kind": {"const": "work_packet"}}},
      "then": {
        "properties": {
          "payload": {
            "required": ["summary", "write_scope", "acceptance", "budget"]
          }
        }
      }
    },
    {
      "if": {"properties": {"kind": {"const": "result"}}},
      "then": {
        "properties": {
          "payload": {
            "required": ["summary", "status", "changed_files", "commands"]
          }
        }
      }
    },
    {
      "if": {"properties": {"kind": {"const": "verdict"}}},
      "then": {
        "properties": {
          "payload": {
            "required": ["summary", "disposition", "evidence_checked"]
          }
        }
      }
    }
  ]
}
